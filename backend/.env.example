# ── AIS Data ──────────────────────────────────────────────
# aisstream.io API key (free signup at aisstream.io - no hardware required)
AISSTREAM_API_KEY=9baf6234424d49397d47755a21109582ef978340

# ── Whale Data ────────────────────────────────────────────
# GBIF does not require a key for occurrence downloads
# OBIS does not require a key for public occurrence data

# Whale Alert API (optional - enhances live sightings)
WHALE_ALERT_API_KEY=your_key_here

# ── App Config ────────────────────────────────────────────
# Environment: development | production
APP_ENV=development

# FastAPI host/port
API_HOST=0.0.0.0
API_PORT=8000

# How often to refresh live AIS data (minutes)
AIS_REFRESH_INTERVAL_MINUTES=15

# ── Data Paths ────────────────────────────────────────────
# Relative to backend/
RAW_DATA_DIR=../data/raw
PROCESSED_DATA_DIR=../data/processed
SHAPEFILES_DIR=../data/shapefiles

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
